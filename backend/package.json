{
  "name": "@rpg/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "postbuild": "npm run copy:frontend",
    "copy:frontend": "node -e \"require('fs').cpSync('../frontend/dist', 'public', {recursive: true, force: true})\"",
    "start": "node dist/index.js"

  },
  "dependencies": {
    "@rpg/shared": "*",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "mongodb": "^6.10.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
