# Backend Environment Variables

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Database Mode (choose one)
# InMemory: no database config needed (default)
# MongoDB: set USE_MONGODB=true
# Cosmos DB SQL API: set USE_COSMOS=true

# MongoDB (Azure Cosmos DB with MongoDB API)
USE_MONGODB=false
# MONGODB_CONNECTION_STRING=mongodb://your-account:your-key@your-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000
# MONGODB_DATABASE=rpg-db

# Cosmos DB SQL API (when USE_COSMOS=true)
USE_COSMOS=false
# COSMOS_ENDPOINT=https://rpg-cosmos.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-primary-key-here
# COSMOS_DATABASE=rpg-db

# For local Cosmos DB Emulator:
# COSMOS_ENDPOINT=https://localhost:8081
# COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
# COSMOS_DATABASE=rpg-db
